# ManualIQ Environment Variables
# Copy to .env and fill in your values.

# --- API Keys (use Docker secrets in production) ---
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...
VOYAGE_API_KEY=pa-...
COHERE_API_KEY=...
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...
RESEND_API_KEY=re_...

# --- Infrastructure ---
QDRANT_URL=http://qdrant:6333
REDIS_URL=redis://redis:6379
DATABASE_URL=postgresql+asyncpg://manualiq:password@postgres:5432/manualiq
PHOENIX_COLLECTOR_ENDPOINT=http://phoenix:4317
OLLAMA_URL=http://ollama:11434

# --- Prefect ---
PREFECT_API_URL=http://prefect-server:4200/api
CORPUS_DIR=/corpus
DEFAULT_TENANT_ID=default
ALERT_EMAIL=admin@manualiq.com

# --- PostgreSQL (used by docker-compose) ---
PG_PASS=change_me_in_production

# --- Application ---
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
LOG_FORMAT=text

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
